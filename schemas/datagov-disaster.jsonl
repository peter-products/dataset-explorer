{"id":"datagov:dbf70dc1-b919-47a5-8aa2-35d33ede7cbd","name":"Disaster Emergency Medical Personnel System (DEMPS)","provider":"Department of Veterans Affairs","source_portal":"catalog.data.gov","source_platform":"ckan","url":"https://catalog.data.gov/dataset/disaster-emergency-medical-personnel-system-demps","api_endpoint":null,"documentation_url":"https://catalog.data.gov/dataset/disaster-emergency-medical-personnel-system-demps","access_method":"download","format":["unknown"],"geographic_scope":"varies","geographic_detail":null,"domain":"health","category":null,"update_frequency":"unknown","row_count":null,"column_count":null,"columns":[],"tags":["clinical","disaster","emergency","management","medical","national","staff","va","veteran"],"description":"The Disaster Emergency Medical Personnel System (DEMPS) is the Veterans Health Administrations main deployment program for clinical and non-clinical staff to an emergency or disaster. The DEMPS Program may be used for an internal VA mission, as well as supporting a mission after a Presidential Disaster Declaration under the National Response Frameworks Emergency Support Function #8 (Public Health and Medical Services). Interested, qualified VHA staff can apply online by submitting a DEMPS Applic","last_updated":"2025-08-02T05:07:32.097160","created_at":"2020-11-10T17:13:52.916631","license":"Creative Commons CCZero","collected_at":"2026-04-11T22:49:47.540Z"}
